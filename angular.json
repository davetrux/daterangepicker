{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "ng-daterangepicker": {
      "projectType": "library",
      "root": "projects/ng-daterangepicker",
      "sourceRoot": "projects/ng-daterangepicker/src",
      "prefix": "drp",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/ng-daterangepicker/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ng-daterangepicker/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/ng-daterangepicker/tsconfig.spec.json"
          }
        }
      }
    },
    "demo": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/demo",
      "sourceRoot": "projects/demo/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/demo/src/main.ts",
            "tsConfig": "projects/demo/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/demo/public"
              }
            ],
            "styles": [
              "node_modules/bootstrap/dist/css/bootstrap.min.css",
              "node_modules/bootstrap-icons/font/bootstrap-icons.css",
              "projects/demo/src/styles.css"
            ],
            "allowedCommonJsDependencies": [
              "dayjs",
              "dayjs/plugin/updateLocale",
              "dayjs/plugin/customParseFormat",
              "dayjs/plugin/isoWeek",
              "dayjs/plugin/localeData",
              "dayjs/plugin/localizedFormat",
              "dayjs/plugin/weekday",
              "dayjs/plugin/arraySupport",
              "dayjs/plugin/weekOfYear",
              "dayjs/plugin/advancedFormat",
              "dayjs/plugin/relativeTime",
              "dayjs/plugin/calendar",
              "dayjs/plugin/isSameOrBefore",
              "dayjs/plugin/isSameOrAfter"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1MB",
                  "maximumError": "2MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "demo:build:production"
            },
            "development": {
              "buildTarget": "demo:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
